        Overrides = deepCopyTable(StudioState.Overrides),
        SavedAt = os.time()
    }
    StudioState.SelectedSaveName = name
    writeSavesToDisk()
    refreshSavesList()
    return true
end

local function loadProfile(name)
    local profile = StudioState.SaveProfiles[name]
    if not profile then
        return false
    end
    StudioState.Overrides = {}
    for k, cfg in pairs(profile.Overrides or {}) do
        StudioState.Overrides[k] = normalizeOverride(k, deepCopyTable(cfg))
    end
    StudioState.SelectedSaveName = name
    if StudioState.CurrentCharacter then
        loadSidebar(StudioState.CurrentCharacter)
        clearEditorPanel()
    end
    refreshSavesList()
    return true
end

