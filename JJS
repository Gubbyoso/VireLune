        MainFrame.Visible = false
        MainScale.Scale = 1
    else
        MainFrame.Visible = true
        MainScale.Scale = 0.86
        TweenService:Create(MainScale, TweenInfo.new(0.22, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Scale = 1
        }):Play()
