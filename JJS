local function updatePreviewCamera()
    local cam = StudioState.Camera
    local offset = Vector3.new(
        math.cos(cam.Pitch) * math.sin(cam.Yaw),
        math.sin(cam.Pitch),
        math.cos(cam.Pitch) * math.cos(cam.Yaw)
    ) * cam.Distance
    VP_Camera.CFrame = CFrame.lookAt(cam.Target + offset, cam.Target)
end

Viewport.MouseEnter:Connect(function()
    StudioState.Camera.Hovered = true
end)
Viewport.MouseLeave:Connect(function()
    StudioState.Camera.Hovered = false
    StudioState.Camera.Dragging = false
end)

UserInputService.InputBegan:Connect(function(input)
    if not StudioState.Camera.Hovered then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        StudioState.Camera.Dragging = true
        StudioState.Camera.LastMouse = input.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if not StudioState.Camera.Hovered then return end

    if input.UserInputType == Enum.UserInputType.MouseMovement and StudioState.Camera.Dragging then
        local last = StudioState.Camera.LastMouse
        if last then
            local delta = input.Position - last
            StudioState.Camera.Yaw = StudioState.Camera.Yaw - delta.X * 0.01
            StudioState.Camera.Pitch = math.clamp(StudioState.Camera.Pitch + delta.Y * 0.008, -1.2, 1.2)
            updatePreviewCamera()
        end
        StudioState.Camera.LastMouse = input.Position
    elseif input.UserInputType == Enum.UserInputType.MouseWheel then
        StudioState.Camera.Distance = math.clamp(StudioState.Camera.Distance - (input.Position.Z * 1.2), 3, 16)
        updatePreviewCamera()
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        StudioState.Camera.Dragging = false
        StudioState.Camera.LastMouse = nil
    end
end)

