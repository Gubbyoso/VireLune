    local function createTimeline(seqIndex)
        local fLabel = create("TextLabel", {Size = UDim2.new(1,0,0,20), BackgroundTransparency = 1, TextColor3 = Color3.new(0.7,0.8,1), Text = string.format("--- Sequence %d Timeline ---", seqIndex), Font = Enum.Font.GothamBold, Parent = EditorContainer})

        createField("Override Asset ID", "rbxassetid://...", config["Anim"..seqIndex], function(t)
            if string.match(t, "^%d+$") then t = "rbxassetid://" .. t end
            config["Anim"..seqIndex] = t
        end)

        local TLContainer = create("Frame", { Size = UDim2.new(1, 0, 0, 72), BackgroundTransparency = 1, Parent = EditorContainer})
        local laneMin = 0.05
        local laneSize = 0.9
        local function makeKnob(color)
            local k = create("TextButton", {Size = UDim2.new(0, 16, 0, 16), AnchorPoint = Vector2.new(0.5, 0.5), BackgroundColor3 = color, Text = "", Parent = TLContainer})
            create("UICorner", {CornerRadius = UDim.new(1,0), Parent = k})
            return k
        end
        
        local ConnectLine = create("Frame", {
            Size = UDim2.new(0, 0, 0, 2),
            Position = UDim2.new(laneMin, 0, 0, 18),
            BackgroundColor3 = Color3.fromRGB(255, 255, 255),
            BorderSizePixel = 0,
            Parent = TLContainer
        })
        local StartKnob = makeKnob(Color3.fromRGB(255, 255, 255))
        local EndKnob = makeKnob(Color3.fromRGB(255, 255, 255))
        
        local TimeInfo = create("TextLabel", { Size = UDim2.new(1, 0, 0, 15), Position = UDim2.new(0, 0, 0, 38), BackgroundTransparency = 1, TextColor3 = Color3.new(0.8,0.8,0.8), Text = "Start: 0.00s | End: 0.00s", Font = Enum.Font.Gotham, TextSize = 10, Parent = TLContainer })

        local dragging = nil
        local currentPreviewTrack = nil
        local totalLength = 5
        local function updateSliders()
            local sX = (StartKnob.Position.X.Scale - laneMin) / laneSize
            local eX = (EndKnob.Position.X.Scale - laneMin) / laneSize
            if sX > eX then sX, eX = eX, sX end
            local calculatedStart = sX * totalLength
            local calculatedLength = (eX - sX) * totalLength

            local startX = laneMin + (sX * laneSize)
            local endX = laneMin + (eX * laneSize)
            ConnectLine.Position = UDim2.new(startX, 0, 0, 18)
            ConnectLine.Size = UDim2.new(math.max(endX - startX, 0), 0, 0, 2)
            
            config["Time"..seqIndex] = math.floor(calculatedStart*100)/100
            config["Length"..seqIndex] = math.floor(calculatedLength*100)/100
            config["End"..seqIndex] = math.floor((calculatedStart + calculatedLength)*100)/100
            TimeInfo.Text = string.format("Start: %.2fs | End: %.2fs", config["Time"..seqIndex], config["End"..seqIndex])
        end
        
        local function initializeKnobs()
            local storedTime = config["Time"..seqIndex] or 0
            local storedLen = config["Length"..seqIndex] or 0
            local sScale = storedTime / totalLength
            local eScale = sScale
            if storedLen == 0 then
                eScale = 1
            else
                eScale = (storedTime + storedLen) / totalLength
            end
            
            StartKnob.Position = UDim2.new(laneMin + (math.clamp(sScale,0,1) * laneSize),0,0,18)
            EndKnob.Position = UDim2.new(laneMin + (math.clamp(eScale,0,1) * laneSize),0,0,18)
            updateSliders()
        end
        initializeKnobs()
        
        local function bindDrag(knob)
            knob.MouseButton1Down:Connect(function() dragging = knob end)
        end
        bindDrag(StartKnob); bindDrag(EndKnob)
        
        table.insert(StudioState.EditorConnections, UserInputService.InputChanged:Connect(function(input)
            if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                local relativeX = math.clamp((input.Position.X - TLContainer.AbsolutePosition.X) / TLContainer.AbsoluteSize.X, laneMin, laneMin + laneSize)
                dragging.Position = UDim2.new(relativeX, 0, 0, 18)
                updateSliders()
            end
        end))
        table.insert(StudioState.EditorConnections, UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = nil end
        end))

        local mainFields = create("Frame", { Size = UDim2.new(1, 0, 0, 1), AutomaticSize = Enum.AutomaticSize.Y, BackgroundTransparency = 1, Parent = EditorContainer })
        local function createMainField(label, placeholder, defaultVal, callback)
            local f = create("Frame", { Size = UDim2.new(1, 0, 0, 30), BackgroundTransparency = 1, Parent = mainFields })
            create("TextLabel", { Size = UDim2.new(0.4, 0, 1, 0), BackgroundTransparency = 1, TextColor3 = Color3.new(1,1,1), Text = label, Font = Enum.Font.Gotham, TextXAlignment = Enum.TextXAlignment.Left, Parent = f})
            local box = create("TextBox", { Size = UDim2.new(0.6, 0, 1, 0), Position = UDim2.new(0.4, 0, 0, 0), BackgroundColor3 = Color3.fromRGB(30,30,35), TextColor3 = Color3.new(1,1,1), PlaceholderText = placeholder, Text = tostring(defaultVal), Font = Enum.Font.Gotham, Parent = f})
            styleCard(box, 5)
            box.FocusLost:Connect(function() callback(box.Text) end)
            return box
        end

        createMainField("Playback Speed", "1", config["Speed"..seqIndex], function(t) config["Speed"..seqIndex] = tonumber(t) or 1 end)
        createMainField("Cut End Time", "0 = auto", config["End"..seqIndex], function(t)
            local parsed = tonumber(t) or 0
            config["End"..seqIndex] = parsed
            if parsed > (config["Time"..seqIndex] or 0) then
                config["Length"..seqIndex] = math.max(parsed - (config["Time"..seqIndex] or 0), 0)
            end
        end)
        createMainField("Reverse?", "true/false", tostring(config["Reverse"..seqIndex]), function(t)
            config["Reverse"..seqIndex] = (string.lower(t or "") == "true")
        end)
        createMainField("Fade In", "0.08", config["FadeIn"..seqIndex], function(t)
            config["FadeIn"..seqIndex] = tonumber(t) or 0.08
        end)
        createMainField("Fade Out", "0.08", config["FadeOut"..seqIndex], function(t)
            config["FadeOut"..seqIndex] = tonumber(t) or 0.08
        end)

        local prevBtn = create("TextButton", {Size = UDim2.new(1,0,0,34), BackgroundColor3 = Color3.fromRGB(28,28,28), TextColor3 = Color3.new(1,1,1), Text = "Play Preview on Viewport", Parent = EditorContainer})
        styleButton(prevBtn, Color3.fromRGB(28, 28, 28), Color3.fromRGB(52, 52, 52))
        prevBtn.MouseButton1Click:Connect(function()
            local d = World:FindFirstChildOfClass("Model")
            if d and config["Anim"..seqIndex] ~= "" then
                local animator = getAnimatorFromModel(d)
                if not animator then
                    prevBtn.Text = "No Animator Found"
                    task.delay(1.5, function()
                        prevBtn.Text = "Play Preview on Viewport"
                    end)
                    return
                end

                for _, prevt in ipairs(animator:GetPlayingAnimationTracks()) do prevt:Stop() end
                
                local a = Instance.new("Animation")
                a.Name = "AntigravityOverride"
                local previewId = tostring(config["Anim"..seqIndex] or "")
                local extracted = string.match(previewId, "%d+")
                if extracted and not string.find(previewId, "rbxassetid://", 1, true) then
                    previewId = "rbxassetid://" .. extracted
                end
                a.AnimationId = previewId
                local t = animator:LoadAnimation(a)
                currentPreviewTrack = t
                local speed = config["Speed"..seqIndex] or 1
                local isReverse = config["Reverse"..seqIndex] == true
                local fadeIn = math.max(tonumber(config["FadeIn"..seqIndex]) or 0.08, 0)
                local fadeOut = math.max(tonumber(config["FadeOut"..seqIndex]) or 0.08, 0)
                local startTime = config["Time"..seqIndex] or 0
                local endTime = config["End"..seqIndex] or 0
                if isReverse and endTime <= 0 then
                    endTime = t.Length > 0 and t.Length or startTime
                end
                if endTime > startTime then
                    config["Length"..seqIndex] = endTime - startTime
                end

                t:Play(fadeIn)
                if isReverse then
                    t.TimePosition = math.max(endTime, startTime)
                    t:AdjustSpeed(-math.abs(speed))
                else
                    t.TimePosition = startTime
                    t:AdjustSpeed(math.abs(speed))
                end
                local cLen = config["Length"..seqIndex]
                if cLen and cLen > 0 then
                    task.delay(cLen, function() if t then t:Stop(fadeOut) end end)
                end
            end
        end)
    end
    
    for seq = 1, MAX_SEQUENCES do
        createTimeline(seq)
    end

