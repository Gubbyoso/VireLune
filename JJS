ApplyImportBtn.MouseButton1Click:Connect(function()
    local clip = ImportBox.Text
    if not clip or clip == "" then
        ApplyImportBtn.Text = "No Text Found!"
        task.delay(2, function() ApplyImportBtn.Text = "Apply Import" end)
        return
    end

    local count = 0
    local decodedOk, decoded = pcall(function()
        return HttpService:JSONDecode(clip)
    end)
    if decodedOk and type(decoded) == "table" then
        for k, cfg in pairs(decoded) do
            StudioState.Overrides[k] = normalizeOverride(k, cfg)
            count = count + 1
        end
    end

    if count == 0 then
        local pattern = '%["(.-)"%] = { GameId = "(.-)", Anim1 = "(.-)", Time1 = (.-), Length1 = (.-), Speed1 = (.-), Anim2 = "(.-)", Time2 = (.-), Length2 = (.-), Speed2 = (.-), Anim3 = "(.-)", Time3 = (.-), Length3 = (.-), Speed3 = (.-), DashEnabled = (.-), DashSpeed = (.-) }'
        for k, GameId, Anim1, Time1, Length1, Speed1, Anim2, Time2, Length2, Speed2, Anim3, Time3, Length3, Speed3, DashEnabled, DashSpeed in string.gmatch(clip, pattern) do
            StudioState.Overrides[k] = normalizeOverride(k, {
                GameId = GameId,
                Anim1 = Anim1, Time1 = tonumber(Time1) or 0, Length1 = tonumber(Length1) or 0, Speed1 = tonumber(Speed1) or 1,
                Anim2 = Anim2, Time2 = tonumber(Time2) or 0, Length2 = tonumber(Length2) or 0, Speed2 = tonumber(Speed2) or 1,
                Anim3 = Anim3, Time3 = tonumber(Time3) or 0, Length3 = tonumber(Length3) or 0, Speed3 = tonumber(Speed3) or 1,
                DashEnabled = (DashEnabled == "true"), DashSpeed = tonumber(DashSpeed) or 50
            })
            count = count + 1
        end
    end
    
    if count > 0 then
        ApplyImportBtn.Text = "Imported " .. count .. "!"
        if StudioState.CurrentCharacter then
            loadSidebar(StudioState.CurrentCharacter)
            for _, v in ipairs(EditorContainer:GetChildren()) do
                if not v:IsA("UIListLayout") then v:Destroy() end
            end
            StudioState.CurrentAnimSelected = nil
        end
        task.delay(1, function()
            local tween = TweenService:Create(ImportFrame, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                BackgroundTransparency = 0.35
            })
            tween:Play()
            tween.Completed:Wait()
            ImportFrame.Visible = false
            ApplyImportBtn.Text = "Apply Import"
        end)
    else
        ApplyImportBtn.Text = "Invalid Format!"
        ApplyImportBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        task.delay(2, function() ApplyImportBtn.Text = "Apply Import"; ApplyImportBtn.BackgroundColor3 = Color3.fromRGB(28, 28, 28) end)
    end
end)

