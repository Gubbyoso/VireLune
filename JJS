local function getOverride(origId)
    if not StudioState.Overrides[origId] then
        StudioState.Overrides[origId] = { GameId = origId, DashEnabled = false, DashSpeed = 50 }
    end
    local target = StudioState.Overrides[origId]
    for i = 1, MAX_SEQUENCES do
        target["Anim"..i] = target["Anim"..i] or ""
        target["Time"..i] = tonumber(target["Time"..i]) or 0
        target["End"..i] = tonumber(target["End"..i]) or 0
        target["Speed"..i] = tonumber(target["Speed"..i]) or 1
        target["Length"..i] = tonumber(target["Length"..i]) or 0
        target["Reverse"..i] = target["Reverse"..i] == true
        target["FadeIn"..i] = tonumber(target["FadeIn"..i]) or 0.08
        target["FadeOut"..i] = tonumber(target["FadeOut"..i]) or 0.08
    end
    return target
end

local function normalizeOverride(k, cfg)
    local normalized = getOverride(k)
    for key, value in pairs(cfg or {}) do
        normalized[key] = value
    end
    normalized.GameId = normalized.GameId or k
    normalized.DashEnabled = normalized.DashEnabled == true
    normalized.DashSpeed = tonumber(normalized.DashSpeed) or 50
    for i = 1, MAX_SEQUENCES do
        normalized["Anim"..i] = normalized["Anim"..i] or ""
        normalized["Time"..i] = tonumber(normalized["Time"..i]) or 0
        normalized["End"..i] = tonumber(normalized["End"..i]) or 0
        normalized["Length"..i] = tonumber(normalized["Length"..i]) or 0
        normalized["Speed"..i] = tonumber(normalized["Speed"..i]) or 1
        normalized["FadeIn"..i] = tonumber(normalized["FadeIn"..i]) or 0.08
        normalized["FadeOut"..i] = tonumber(normalized["FadeOut"..i]) or 0.08
        normalized["Reverse"..i] = normalized["Reverse"..i] == true
    end
    return normalized
end

local function parseAnimations()
    if not AnimationsFolder then warn("No Animations folder found in ReplicatedStorage!") return end
    
    for _, charFolder in ipairs(AnimationsFolder:GetChildren()) do
        if charFolder:IsA("Folder") and charFolder.Name ~= "Misc" then
            local charData = { Melee = {}, Skills = {}, Ults = {} }
            
            for _, sub in ipairs(charFolder:GetDescendants()) do
                if sub:IsA("Animation") then
                    local cat = "Skills"
                    local parentName = sub.Parent and sub.Parent.Name:lower() or ""
                    local subName = sub.Name:lower()
                    
                    if string.find(parentName, "melee") or string.find(subName, "melee") then
                        cat = "Melee"
                    elseif string.find(parentName, "ult") or string.find(subName, "ult") or string.find(parentName, "awakening") then
                        cat = "Ults"
                    end
                    
                    table.insert(charData[cat], {
                        Name = sub.Name,
                        Id = string.match(tostring(sub.AnimationId), "%d+") or sub.AnimationId,
                        Instance = sub
                    })
                end
            end
            
            table.sort(charData.Melee, function(a,b) return a.Name < b.Name end)
            table.sort(charData.Skills, function(a,b) return a.Name < b.Name end)
            table.sort(charData.Ults, function(a,b) return a.Name < b.Name end)
            
            StudioState.Characters[charFolder.Name] = charData
        end
    end
end

parseAnimations()

local function create(className, props)
    local inst = Instance.new(className)
    for k, v in pairs(props) do
        if k ~= "Parent" then
            inst[k] = v
        end
    end
    if props.Parent then inst.Parent = props.Parent end
    return inst
end

