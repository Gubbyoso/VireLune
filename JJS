local function playCustomSequence(config, onFinished)
    StudioState.SequenceID = (StudioState.SequenceID or 0) + 1
    local currentSeq = StudioState.SequenceID

    local char = LocalPlayer.Character
    if not char then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChild("Humanoid")
    if not hrp or not humanoid then return end
    
    local animator = humanoid:FindFirstChild("Animator") or humanoid
    
    for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
        if track.Animation and track.Animation.Name == "AntigravityOverride" then
            track:Stop()
        end
    end
    
    task.spawn(function()
        local ok, err = pcall(function()
        if config.DashEnabled then
            local speed = config.DashSpeed or 50
            local lookVector = hrp.CFrame.LookVector
            local dir = Vector3.new(lookVector.X, 0, lookVector.Z).Unit
            local startTime = tick()
            local conn
            conn = RunService.Heartbeat:Connect(function()
                if tick() - startTime >= 0.4 or StudioState.SequenceID ~= currentSeq then 
                    conn:Disconnect() 
                    return 
                end
                hrp.Velocity = dir * speed
            end)
        end
        
        local function invokeAnimPhase(seqIndex)
            if StudioState.SequenceID ~= currentSeq then return false end
            
            local aID = config["Anim"..seqIndex]
            if not aID or aID == "" then return false end
            
            local a = Instance.new("Animation")
            a.Name = "AntigravityOverride"
            a.AnimationId = aID
            local t = animator:LoadAnimation(a)
            t.Looped = false
            local speed = config["Speed"..seqIndex] or 1
            local isReverse = config["Reverse"..seqIndex] == true
            local fadeIn = math.max(tonumber(config["FadeIn"..seqIndex]) or 0.08, 0)
            local fadeOut = math.max(tonumber(config["FadeOut"..seqIndex]) or 0.08, 0)
            local startTime = config["Time"..seqIndex] or 0
            local endTime = config["End"..seqIndex] or 0

            if isReverse and endTime <= 0 then
                endTime = t.Length > 0 and t.Length or startTime
            end
            if endTime > startTime then
                config["Length"..seqIndex] = endTime - startTime
            end

            t:Play(fadeIn)
            if isReverse then
                t.TimePosition = math.max(endTime, startTime)
                t:AdjustSpeed(-math.abs(speed))
            else
                t.TimePosition = startTime
                t:AdjustSpeed(math.abs(speed))
            end
            
            local cLen = config["Length"..seqIndex] or 0
            if cLen > 0 then
                local eTick = tick() + cLen
                while tick() < eTick do
                    if StudioState.SequenceID ~= currentSeq then break end
                    task.wait(0.01)
                end
                if t then t:Stop(fadeOut) end
            else
                if t.Length > 0 then
                    local targetWait = t.Length - t.TimePosition
                    local eTick = tick() + targetWait
                    while tick() < eTick do
                        if StudioState.SequenceID ~= currentSeq then break end
                        task.wait(0.01)
                    end
                    if t then t:Stop(fadeOut) end
                else
                    t.Ended:Wait()
                    if t then t:Stop(fadeOut) end
                end
            end
            
            return StudioState.SequenceID == currentSeq
        end
        
        for seq = 1, MAX_SEQUENCES do
            local hasAnim = config["Anim"..seq]
            if hasAnim and hasAnim ~= "" then
                local continuePipeline = invokeAnimPhase(seq)
                if not continuePipeline then
                    break
                end
            end
        end
        end)

        if not ok then
            warn("[Antigravity V4] Sequence execution error:", err)
        end

        if onFinished then
            onFinished()
        end
    end)
end

playSequenceFE = function(config, sourceAnimId, onFinished)
    if SequenceRemote and SequenceRemote:IsA("RemoteEvent") then
        local ok = pcall(function()
            SequenceRemote:FireServer(sourceAnimId, config)
        end)
        if ok then
            if onFinished then onFinished() end
            return
        end
    end
    playCustomSequence(config, onFinished)
end

local function releaseTriggerLock(animId)
    if not StudioState.ActiveTriggerLocks then return end
    StudioState.ActiveTriggerLocks[animId] = nil
end

local function acquireTriggerLock(animId)
    StudioState.ActiveTriggerLocks = StudioState.ActiveTriggerLocks or {}
    StudioState.TriggerLockUntil = StudioState.TriggerLockUntil or {}

    local now = tick()
    local lockedUntil = StudioState.TriggerLockUntil[animId]
    if StudioState.ActiveTriggerLocks[animId] or (lockedUntil and now < lockedUntil) then
        return false
    end

    StudioState.ActiveTriggerLocks[animId] = true
    StudioState.TriggerLockUntil[animId] = now + 0.9
    return true
end

local function onAnimationPlayed(animTrack)
    if not animTrack.Animation then return end
    if animTrack.Animation.Name == "AntigravityOverride" then return end 
    
    local rawAnimId = tostring(animTrack.Animation.AnimationId)
    local extractedId = string.match(rawAnimId, "%d+") or rawAnimId
    
    if StudioState.LastPlayedID == extractedId and (tick() - (StudioState.LastPlayedTime or 0)) < 0.4 then
        return
    end
    StudioState.LastPlayedID = extractedId
    StudioState.LastPlayedTime = tick()
    
    local config = StudioState.Overrides[extractedId]
    
    if not config then
        for k, v in pairs(StudioState.Overrides) do
            if tostring(v.GameId) == extractedId then
                config = v
                break
            end
        end
    end

    if config and config.Anim1 and config.Anim1 ~= "" then
        config = normalizeOverride(extractedId, config)
        if not acquireTriggerLock(extractedId) then
            return
        end

        print("[Antigravity V4] EXECUTION SUCCESS:", extractedId)
        animTrack:Stop()
        playSequenceFE(config, extractedId, function()
            releaseTriggerLock(extractedId)
        end)
    end
end

local function hookCharacter(character)
    local humanoid = character:WaitForChild("Humanoid", 10)
    if humanoid then
        local animator = humanoid:WaitForChild("Animator", 3) or humanoid
        if StudioState.Connections then StudioState.Connections:Disconnect() end
        StudioState.Connections = animator.AnimationPlayed:Connect(onAnimationPlayed)
    end
end

if LocalPlayer.Character then hookCharacter(LocalPlayer.Character) end
LocalPlayer.CharacterAdded:Connect(hookCharacter)

